# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Destination image library (flyg.ai import) ---
# ~1010 flights-* images (144MB) live on disk but are NOT tracked.
# Only images referenced in the codebase are committed (negated below).
/public/images/destinations/flights-*
!/public/images/destinations/flights-bali-thumb.avif
!/public/images/destinations/flights-bali.avif
