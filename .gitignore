# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# --- Destination image library (flyg.ai import) ---
# Hero images (flights-*.avif) ARE tracked so every destination page renders.
# The slim thumbnails (flights-*-thumb.avif) are unused in code and stay ignored
# (the 8 rich thumbnails committed earlier remain tracked).
/public/images/destinations/flights-*-thumb.avif
!/public/images/destinations/flights-bali-thumb.avif
!/public/images/destinations/flights-barcelona-thumb.avif
!/public/images/destinations/flights-lisbon-thumb.avif
!/public/images/destinations/flights-marrakech-thumb.avif
!/public/images/destinations/flights-new-york-thumb.avif
!/public/images/destinations/flights-reykjavik-thumb.avif
!/public/images/destinations/flights-tokyo-thumb.avif
